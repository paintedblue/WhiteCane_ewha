# 서버 URL (백엔드 API 서버 주소)
SERVER_URL=http://localhost:8000/

# 네이버 지도 Client ID (NCP 콘솔 > Application > Maps SDK)
NAVER_MAP_CLIENT_ID=your_naver_map_client_id_here

# 네이버 Directions 5 API 키 (NCP 콘솔 > Application > Maps > Directions 5)
NAVER_DIRECTIONS_CLIENT_ID=your_directions_client_id_here
NAVER_DIRECTIONS_CLIENT_SECRET=your_directions_client_secret_here

# 네이버 장소 검색 API 키 (developers.naver.com > 애플리케이션 > 지역 검색)
NAVER_SEARCH_CLIENT_ID=your_search_client_id_here
NAVER_SEARCH_CLIENT_SECRET=your_search_client_secret_here
